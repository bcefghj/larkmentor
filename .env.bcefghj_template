# LarkMentor Agent-Pilot v2 环境配置
# 基于 bcefghj 开发者账号的权限配置模板

# === 飞书开放平台（必填） ===
FEISHU_APP_ID=cli_xxxxxxxxx  # 从"凭证与基础信息"获取
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx  # 点击"查看"获取

# === 火山方舟 LLM（必填） ===
ARK_API_KEY=ark-xxxxxxxxxxxx  # 火山方舟控制台获取
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-pro-32k

# === Agent-Pilot Dashboard（必填） ===
DASHBOARD_PORT=8001
DASHBOARD_HOST=0.0.0.0

# === 飞书多维表格（可选，您已开通 bitable:app 权限） ===
BITABLE_APP_TOKEN=  # 可选：用于结构化数据存储
BITABLE_TABLE_ID=   # 可选：数据表 ID

# === MCP 服务（Agent 间通信） ===
MCP_PORT=8767
MCP_HOST=127.0.0.1

# === 其他配置 ===
LOG_LEVEL=INFO
DATA_DIR=./data
ARTIFACTS_DIR=./data/pilot_artifacts

# === 权限状态检查清单 ===
# ✅ 已确认开通（根据您的截图）:
#   - bitable:app (多维表格读写)
#   - bitable:app:readonly (多维表格只读)  
#   - calendar:calendar (日历读写)
#   - attendance:task (打卡数据)
#   - approval:task (审批任务)

# ❓ 需要确认状态的关键权限:
#   - im:message (获取发送消息) - 【核心功能】
#   - im:message:send_as_bot (Bot发送消息) - 【核心功能】
#   - docx:document (文档读写) - 【核心功能】  
#   - contact:user.base:readonly (用户信息) - 【核心功能】
#   - board:whiteboard:node:* (画板操作) - 【架构图功能】
#   - minutes:minutes (语音转写) - 【语音指令功能】

# === 启动验证命令 ===
# 1. 启动 Bot: python main.py
# 2. 启动 Dashboard: uvicorn dashboard.server:app --host 0.0.0.0 --port 8001  
# 3. 启动 MCP: python -m core.mcp_server.main
# 4. 验证: 飞书私聊 Bot 发送 "/pilot help"