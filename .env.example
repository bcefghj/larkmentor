# === 飞书应用凭证 ===
# 在飞书开放平台 https://open.feishu.cn/app 创建自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 火山方舟 LLM API ===
# Coding Plan 专用 Base URL（不消耗额外费用）
ARK_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_MODEL=doubao-seed-2.0-pro

# === 飞书多维表格（可选，用于打断分析数据存储）===
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=

# === 邮件 SMTP（可选，P0 紧急消息兜底）===
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASS=your_smtp_authorization_code
NOTIFY_EMAIL=your_email@163.com

# === Webhook 预留（Bark / Server酱 / 钉钉 等，留空则跳过）===
WEBHOOK_BARK_URL=
WEBHOOK_SERVERCHAN_KEY=
WEBHOOK_DINGTALK_URL=

# === Agent-Pilot 核心配置 ===
DEFAULT_FOCUS_DURATION=30
DAILY_REPORT_HOUR=18
DAILY_REPORT_MINUTE=0
CALENDAR_POLL_MINUTES=5

# === Dashboard ===
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0
AGENT_PILOT_DEMO_MODE=false

# === v8 新增 ===
# AGENT_PILOT_API_KEY=        # Dashboard API鉴权（留空则开放）
# AGENT_PILOT_SHARE_SECRET=   # 分享链接签名密钥
# CORS_ORIGINS=*              # CORS允许来源

# === 备用 LLM (可选) ===
# MINIMAX_GROUP_ID=
# MINIMAX_API_KEY=
# DEEPSEEK_API_KEY=
# KIMI_API_KEY=
